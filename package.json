{
  "name": "transcribethis",
  "version": "1.0.0",
  "description": "Aplicativo web para transcrição manual de áudio e vídeo com controles avançados e editor Vim.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.transcribethis.app",
    "productName": "transcribeThis - Transcritor de Áudio",
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "keywords": [],
  "author": {
    "name": "Gabriel Aires",
    "email": "resetim@protonmail.com"
  },
  "license": "ISC",
  "homepage": "https://github.com/gabriel-aires09/transcribeThis"
}
